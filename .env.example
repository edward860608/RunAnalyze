# Optional local environment values for RunAnalyze.
# Streamlit Community Cloud should use app secrets instead of this file.

RUNANALYZE_DATA_SOURCE=sample

# Google Sheets mode
SPREADSHEET_ID=
GOOGLE_SHEET_NAME=RunAnalyze
GOOGLE_RUNS_WORKSHEET=runs
GOOGLE_SPLITS_WORKSHEET=run_splits
RUNS_SHEET_NAME=runs
SPLITS_SHEET_NAME=run_splits
GOOGLE_SERVICE_ACCOUNT_JSON=
GSHEET_SPREADSHEET_ID=
GSHEET_SERVICE_ACCOUNT_JSON=

# Strava ETL mode, for future scripts
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
LOOKBACK_DAYS=30
SLEEP_EVERY_N=10
SLEEP_SECONDS=1.0

# Daily AI report mode
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.4
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
REPORT_TO_EMAIL=
REPORT_FROM_EMAIL=
REPORT_SUBJECT_PREFIX=[Running Daily]
REPORT_RECENT_N_RUNS=6
REPORT_LOOKBACK_DAYS=60
REPORT_MAX_SPLITS_PER_RUN=40
